{
  "1": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "SDXL\\sd_xl_base_1.0.safetensors"}},
  "2": {"class_type": "LoraLoader", "inputs": {"lora_name": "pixel_art_v1.safetensors", "strength_model": 1.3, "strength_clip": 1, "model": ["1", 0], "clip": ["1", 1]}},
  "3": {"class_type": "CLIPTextEncode", "inputs": {"text": "tileable pixel art game tile, {{tile_type}}, seamless edges, {{positive_prompt}}, compatible with tilemap editor, consistent style, game asset pack", "clip": ["2", 1]}},
  "4": {"class_type": "CLIPTextEncode", "inputs": {"text": "asymmetric, visible seams, broken edges, 3d perspective, realistic, low quality, blurry, watermark", "clip": ["2", 1]}},
  "5": {"class_type": "EmptyLatentImage", "inputs": {"width": 256, "height": 256, "batch_size": "{{tile_count}}"}},
  "6": {"class_type": "KSampler", "inputs": {"seed": "{{seed}}", "steps": 25, "cfg": 7.5, "sampler_name": "dpmpp_2m_karras", "scheduler": "normal", "denoise": 1, "model": ["2", 0], "positive": ["3", 0], "negative": ["4", 0], "latent_image": ["5", 0]}},
  "7": {"class_type": "VAEDecode", "inputs": {"samples": ["6", 0], "vae": ["1", 2]}},
  "8": {"class_type": "ImageUpscaleWithModel", "inputs": {"model": "4x_NMKD_Superscale_SP_200000", "image": ["7", 0]}},
  "9": {"class_type": "ImageScale", "inputs": {"width": 64, "height": 64, "method": "nearest", "image": ["8", 0]}},
  "10": {"class_type": "TileEdgeProcessor", "inputs": {"tile_size": 64, "blend_pixels": 4, "image": ["9", 0]}},
  "11": {"class_type": "PixelArtFilter", "inputs": {"palette_size": 8, "dithering": "ordered", "image": ["10", 0]}},
  "12": {"class_type": "ImageBatchToList", "inputs": {"images": ["11", 0]}},
  "13": {"class_type": "TilePaletteExtract", "inputs": {"images": ["12", 0], "max_colors": 16}},
  "14": {"class_type": "TilesetComposer", "inputs": {"tile_width": 64, "tile_height": 64, "columns": 8, "images": ["12", 0]}},
  "15": {"class_type": "MetadataWriter", "inputs": {"metadata": {"tile_count": "{{tile_count}}", "tile_size": 64, "format": "png", "palette": ["13", 0]}, "images": ["14", 0]}},
  "16": {"class_type": "SaveImage", "inputs": {"filename_prefix": "omnitileset", "images": ["15", 0]}}
}