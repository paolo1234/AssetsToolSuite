{
  "1": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "SDXL\\sd_xl_base_1.0.safetensors"}},
  "2": {"class_type": "LoraLoader", "inputs": {"lora_name": "ui_icon_v1.safetensors", "strength_model": 1.0, "strength_clip": 1, "model": ["1", 0], "clip": ["1", 1]}},
  "3": {"class_type": "CLIPTextEncode", "inputs": {"text": "clean {{ui_element_type}}, game ui icon, crisp vector style, {{positive_prompt}}, flat design, solid colors, minimal details, icon set style", "clip": ["2", 1]}},
  "4": {"class_type": "CLIPTextEncode", "inputs": {"text": "3d, realistic, shadows, gradients, complex background, messy, low quality, blurry, photograph, detailed texture", "clip": ["2", 1]}},
  "5": {"class_type": "EmptyLatentImage", "inputs": {"width": 256, "height": 256, "batch_size": "{{count}}"}},
  "6": {"class_type": "KSampler", "inputs": {"seed": "{{seed}}", "steps": 20, "cfg": 7, "sampler_name": "euler", "scheduler": "normal", "denoise": 1, "model": ["2", 0], "positive": ["3", 0], "negative": ["4", 0], "latent_image": ["5", 0]}},
  "7": {"class_type": "VAEDecode", "inputs": {"samples": ["6", 0], "vae": ["1", 2]}},
  "8": {"class_type": "ImageUpscaleWithModel", "inputs": {"model": "4x_NMKD_Superscale_SP_200000", "image": ["7", 0]}},
  "9": {"class_type": "ImageScale", "inputs": {"width": 64, "height": 64, "method": "nearest", "image": ["8", 0]}},
  "10": {"class_type": "ImagePad", "inputs": {"left": 16, "top": 16, "right": 16, "bottom": 16, "color": "#00000000", "image": ["9", 0]}},
  "11": {"class_type": "SolidColorOverlay", "inputs": {"color": "{{highlight_color}}", "opacity": 0.3, "image": ["10", 0]}},
  "12": {"class_type": "ImageComposite", "inputs": {"x": 0, "y": 0, "over": ["10", 0], "under": "hover_state.png"}},
  "13": {"class_type": "BatchSave", "inputs": {"prefix": "omni_ui", "images": ["12", 0]}}
}